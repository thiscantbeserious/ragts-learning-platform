#!/usr/bin/env bash

COMMIT_MSG=$(cat "$1")
REPO_ROOT=$(git rev-parse --show-toplevel)

# --- Scope validation ---
# Scopes from workflow variant git contracts (single source of truth)
# Parses "| Commit scopes | `scope1`, `scope2` |" lines
VALID_SCOPES=()
VARIANT_MAP=""
for variant in "$REPO_ROOT"/agents/skills/workflow/variants/*.md; do
  [ -f "$variant" ] || continue
  name=$(basename "$variant" .md)
  scopes=$(grep -i 'commit scopes' "$variant" | grep -oE '`[a-z0-9-]+`' | tr -d '`' | tr '\n' ' ')
  [ -z "$scopes" ] && continue
  VARIANT_MAP+="  $name: $scopes"$'\n'
  for s in $scopes; do
    VALID_SCOPES+=("$s")
  done
done
VALID_SCOPES=($(printf '%s\n' "${VALID_SCOPES[@]}" | sort -u))

if [[ "$COMMIT_MSG" =~ ^[a-z]+\(([a-z0-9-]+)\): ]]; then
  SCOPE="${BASH_REMATCH[1]}"
  VALID=false
  for s in "${VALID_SCOPES[@]}"; do
    [[ "$SCOPE" == "$s" ]] && VALID=true && break
  done
  if [[ "$VALID" == "false" ]]; then
    echo ""
    echo "ERROR: Invalid commit scope '($SCOPE)'"
    echo ""
    echo "Scopes per variant:"
    echo "$VARIANT_MAP"
    echo "Commit: $COMMIT_MSG"
    echo ""
    exit 1
  fi
fi

# --- Snapshot guard ---
# Blocks snapshot file changes unless commit message contains [snapshot-update].
SNAP_FILES=$(git diff --cached --name-only --diff-filter=ACDMR | grep -E '\.(snap|png)$' | grep -E '(__snapshots__|__screenshots__)' || true)

if [ -n "$SNAP_FILES" ] && ! echo "$COMMIT_MSG" | grep -qF '[snapshot-update]'; then
  echo ""
  echo "ERROR: Snapshot files changed but commit message is missing [snapshot-update] tag."
  echo ""
  echo "Changed snapshot files:"
  echo "$SNAP_FILES" | sed 's/^/  /'
  echo ""
  echo "If this is intentional, add [snapshot-update] to your commit message."
  echo "If not, unstage these files or investigate why they changed."
  echo ""
  exit 1
fi
