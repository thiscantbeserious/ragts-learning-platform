// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ToastContainer component snapshots > error toast 1`] = `
"<div data-v-dd40d1fc="" class="toast-stack">
  <div data-v-dd40d1fc="" class="toast toast--error">
    <div data-v-dd40d1fc="" class="toast__icon"><span data-v-dd40d1fc="" class="icon icon--md icon-error-circle"></span></div>
    <div data-v-dd40d1fc="" class="toast__content">
      <!--v-if-->
      <div data-v-dd40d1fc="" class="toast__message">Upload failed: invalid file type</div>
    </div><button data-v-dd40d1fc="" class="toast__close" aria-label="Dismiss notification"><span data-v-dd40d1fc="" class="icon icon--sm icon-close"></span></button>
  </div>
</div>"
`;

