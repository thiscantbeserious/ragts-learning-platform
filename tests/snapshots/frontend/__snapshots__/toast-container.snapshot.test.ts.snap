exports[`ToastContainer component snapshots > multiple toasts stacked 1`] = `
"<div data-v-dd40d1fc="" class="toast-stack">
  <div data-v-dd40d1fc="" class="toast toast--success">
    <div data-v-dd40d1fc="" class="toast__icon"><span data-v-dd40d1fc="" class="icon icon--md icon-check-circle"></span></div>
