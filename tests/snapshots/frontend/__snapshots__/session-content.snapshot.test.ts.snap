        </button>
        <div data-v-f4ff43c4="" class="section-content">
          <div data-v-f4ff43c4="" class="section-empty"> No content captured </div>
        </div>
      </div>
    </div>
    <!--v-if-->
  </div>
</div>"
`;

exports[`SessionContent component snapshots > virtual mode — renders virtual container with total height 1`] = `
"<div data-v-b8c49044="" class="terminal-chrome">
  <div data-v-5d73d589="" data-v-b8c49044="" class="overlay-scrollbar terminal-scroll">
    <div data-v-5d73d589="" class="overlay-scrollbar__viewport">
      <!-- Error banner for failed sessions that have partial sections -->
      <!--v-if-->
      <!-- Virtual mode: absolutely positioned items within a sized container -->
      <div data-v-b8c49044="" class="section-virtual-container" style="height: 200px; position: relative;">
        <div data-v-f4ff43c4="" data-v-b8c49044="" class="section-item" data-index="0" style="position: absolute; top: 0px; left: 0px; width: 100%; transform: translateY(0px);"><button data-v-a902c83d="" data-v-f4ff43c4="" class="section-header section-header--marker">
            <div data-v-a902c83d="" class="section-header__chevron"><span data-v-a902c83d="" class="icon icon--sm icon-chevron-down"></span></div><span data-v-a902c83d="" class="section-header__label">First</span><span data-v-a902c83d="" class="section-header__range">L1–L10 (5&nbsp;lines)</span><span data-v-a902c83d="" class="badge badge--sm section-header__badge badge--secondary">Marker</span>
          </button>
          <div data-v-f4ff43c4="" class="section-content">
            <div data-v-f4ff43c4="" class="section-empty"> No content captured </div>
          </div>
        </div>
      </div>
    </div>
    <!--v-if-->
  </div>
</div>"
`;
