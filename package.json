{
  "name": "ragts",
  "version": "0.1.0",
  "description": "Reinforced Human Learning Platform - Browse, explore, and learn from AI agent terminal sessions",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 || >=24"
  },
  "imports": {
    "#vt-wasm": "./packages/vt-wasm/index.js",
    "#vt-wasm/types": "./packages/vt-wasm/types.js"
  },
  "scripts": {
    "predev": "node -e \"try{process.kill(+(require('child_process').execSync('lsof -ti:3000 2>/dev/null').toString().trim()),9)}catch{}\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/start.ts",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:server": "tsc -p tsconfig.build.json",
    "build:wasm": "cd packages/vt-wasm && ./build.sh",
    "start": "NODE_ENV=production node dist/server/src/server/start.js",
    "test": "vitest",
    "test:unit": "vitest run --exclude tests/snapshots --exclude tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:snapshot": "vitest run tests/snapshots",
    "test:visual": "npx playwright test",
    "test:all": "vitest run && npx playwright test",
    "test:update-snapshots": "vitest run tests/snapshots --update",
    "test:migrations": "vitest run --config scripts/migrations/vitest.config.ts",
    "migrate:v2": "tsx src/server/scripts/migrate_v2.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev:design": "serve design -l 3333 --no-clipboard",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.6.2",
    "hono": "^4.11.9",
    "hono-pino": "^0.10.3",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "vue": "^3.5.28",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "serve": "^14.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
  }
}
